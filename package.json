{
  "name": "timesheet-enterprise",
  "private": true,
  "version": "1.0.0",
  "description": "Timesheet & HRMS — React frontend (Vercel) + Node.js backend (Render) + Supabase.",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "npm --workspace frontend run dev",
