# Backend Environment Variables
# Copy this file to .env for local development

# Server port (Render sets this automatically)
PORT=4000

# Supabase PostgreSQL connection string
# Get this from: Supabase Dashboard → Project → Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Allowed CORS origin (your Vercel frontend URL)
# Local: http://localhost:5173
# Production: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# Optional: Path to the stakeholder headcount Excel file
# In production, upload the file somewhere accessible and set this path
STAKEHOLDER_HEADCOUNT_FILE=./headcount.xlsx
